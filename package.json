{
  "name": "ourjdownloader",
  "description": "OurJDownloader",
  "version": "2.0.4",
  "author": "Brawl345",
  "license": "Unlicense",
  "repository": {
    "url": "https://github.com/Brawl345/ourjdownloader"
  },
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "lint:types": "wxt prepare && vue-tsc --noEmit",
    "lint:code": "biome lint",
    "lint:code-fix": "biome lint --fix",
    "format": "biome format --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "tsx scripts/release.ts"
  },
  "dependencies": {
    "crypto-es": "3.1.3",
    "vue": "3.5.35"
  },
  "overrides": {
    "tmp": ">=0.2.6",
    "uuid": ">=11.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/chrome": "0.1.42",
    "@vue/test-utils": "2.4.10",
    "@wxt-dev/module-vue": "1.0.3",
    "happy-dom": "20.9.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "vue-tsc": "3.3.3",
    "wxt": "0.20.26"
  }
}
